# ============================================
# 🗄️ 数据库配置
# ============================================
# MySQL 连接字符串（请修改为你的实际配置）
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/rag_ecommerce

# ============================================
# 🔐 安全配置
# ============================================
# JWT 密钥（生产环境务必修改！启动时会自动生成并保存到 .secret_key 文件）
SECRET_KEY=your-secret-key-change-in-production
# JWT 签名算法
ALGORITHM=HS256
# Token 有效期（分钟），默认 24 小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 🗄️ Milvus 向量数据库配置
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============================================
# 🤖 LLM 服务配置 (Ollama)
# ============================================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# ============================================
# 📊 Embedding 向量模型配置
# ============================================
EMBEDDING_MODEL=BAAI/bge-large-zh
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NUM_WORKERS=1
EMBEDDING_MAX_TOKENS=256

# ============================================
# 📚 Milvus 集合配置
# ============================================
COLLECTION_NAME=knowledge_vectors
AUTO_BOOTSTRAP_KNOWLEDGE_INDEXES=true
AUTO_BOOTSTRAP_KNOWLEDGE_INDEXES_MODE=if_empty

# ============================================
# 🔄 Redis 缓存配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_SIMILARITY_THRESHOLD=0.95

# ============================================
# 📁 文件上传配置
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ============================================
# 🎯 Milvus HNSW 索引参数
# ============================================
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=48

# ============================================
# 🔍 重排序模型配置 (Rerank)
# ============================================
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATE_MULTIPLIER=2
RETRIEVAL_TOP_K=5

# ============================================
# ⚡ 性能优化：GPU 资源分配策略
# ============================================
USE_GPU=false
FORCE_EMBEDDING_CPU=true
FORCE_RERANK_CPU=true

# ============================================
# 🌐 CORS 跨域配置
# ============================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
